{
  "name": "paprika-mcp-server",
  "version": "2.1.0",
  "description": "MCP server that provides AI assistants access to Paprika Recipe Manager data",
  "bin": {
    "paprika-mcp-server": "./dist/index.cjs"
  },
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint",
    "fix": "eslint --fix",
    "build": "node esbuild.config.js && chmod +x dist/index.cjs",
    "package": "mcpb pack . paprika-mcp-server.mcpb",
    "version": "changeset version && node scripts/sync-manifest-version.js",
    "start": "tsx src/index.ts"
  },
  "files": [
    "dist"
  ],
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/unzipper": "^0.10.11",
    "esbuild": "^0.28.0",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@rushstack/ts-command-line": "^5.3.4",
    "jiti": "^2.6.1",
    "unzipper": "^0.12.3",
    "zod-to-json-schema": "^3.25.2"
  }
}